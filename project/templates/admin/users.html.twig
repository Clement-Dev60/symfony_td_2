{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs{% endblock %}

{% block body %}
<div class="card">
    <div class="card-title"><h1>Gestion des utilisateurs</h1></div>

    <a href="{{ path('app_admin') }}" class="btn btn-danger">Retour au panel</a>

    <table>
    <thead>
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Rôle</th>
            <th>Vérifié</th>
            <th>Inscrit le</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for user in users %}
            <tr>
                <td data-label="Nom">{{ user.lastName }}</td>
                <td data-label="Prénom">{{ user.firstName }}</td>
                <td data-label="Email">{{ user.email }}</td>
                <td data-label="Rôle">
                    <form method="post" action="{{ path('app_admin_user_role', {'id': user.id}) }}">
                        <select name="role" onchange="this.form.submit()">
                            <option value="" {% if 'ROLE_ADMIN' not in user.roles and 'ROLE_MODERATOR' not in user.roles %}selected{% endif %}>Utilisateur</option>
                            <option value="ROLE_MODERATOR" {% if 'ROLE_MODERATOR' in user.roles %}selected{% endif %}>Modérateur</option>
                            <option value="ROLE_ADMIN" {% if 'ROLE_ADMIN' in user.roles %}selected{% endif %}>Administrateur</option>
                        </select>
                    </form>
                </td>
                <td data-label="Vérifié">{{ user.emailVerifiedAt ? 'Oui' : 'Non' }}</td>
                <td data-label="Inscrit le">{{ user.createdAt|date('d/m/Y') }}</td>
                <td data-label="Actions">
                    <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}" class="btn btn-secondary">Modifier</a>
                    <form method="post" action="{{ path('app_admin_user_delete', {'id': user.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Supprimer cet utilisateur ?')">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
</div>
{% endblock %}