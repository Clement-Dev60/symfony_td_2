{% extends 'base.html.twig' %}

{% block title %}Nouvelle catégorie{% endblock %}

{% block body %}
    <h1>Nouvelle catégorie</h1>

    <a href="{{ path('app_admin_categories') }}">Retour à la liste</a>

    {{ form_start(form) }}
        {{ form_row(form.name) }}
        <button type="submit">Créer</button>
    {{ form_end(form) }}
{% endblock %}