{% extends 'base.html.twig' %}

{% block title %}Panel Admin{% endblock %}

{% block body %}
    <h1>Panel Admin</h1>

    <h2>Statistiques</h2>
    <p>Utilisateurs : {{ users|length }}</p>
    <p>Annonces : {{ listings|length }}</p>
    <p>Catégories : {{ categories|length }}</p>

    <h2>Gestion</h2>
    <a href="{{ path('app_admin_users') }}">Gérer les utilisateurs</a>
<a href="{{ path('app_admin_listings') }}">Gérer les annonces</a>
<a href="{{ path('app_admin_categories') }}">Gérer les catégories</a>
{% endblock %}