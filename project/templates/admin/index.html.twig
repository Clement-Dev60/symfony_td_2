{% extends 'base.html.twig' %}

{% block title %}Panel Admin{% endblock %}

{% block body %}
<div class="card">
    <div class="card-title"><h1>Panel Admin</h1></div>

    <h2>Statistiques</h2>
    <p>Utilisateurs : {{ users|length }}</p>
    <p>Annonces : {{ listings|length }}</p>
    <p>Catégories : {{ categories|length }}</p>

    <h2>Gestion</h2>
    <a href="{{ path('app_admin_users') }}" class="btn btn-primary">Gérer les utilisateurs</a>
    <a href="{{ path('app_admin_listings') }}" class="btn btn-primary">Gérer les annonces</a>
    <a href="{{ path('app_admin_categories') }}" class="btn btn-primary">Gérer les catégories</a>
</div>
{% endblock %}