{% extends 'base.html.twig' %}

{% block title %}Dealgames - Accueil{% endblock %}

{% block body %}

<h1>Les dernières annonces</h1>

{% if listings is empty %}
    <p class="text-muted">Aucune annonce disponible pour le moment.</p>
{% else %}
    <div class="grid mt-20">
        {% for listing in listings %}
            {% include 'components/_card.html.twig' with {
                title: listing.title,
                image: listing.photoPath,
                location: listing.location ?? 'Non précisé',
                date: listing.createdAt|date('d/m/Y'),
                platform: listing.category.name ?? 'Autre',
                isNew: true
            } %}
        {% endfor %}
    </div>
{% endif %}

{% endblock %}