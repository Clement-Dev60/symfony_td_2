{% extends 'base.html.twig' %}

{% block title %}Dealgames - Accueil{% endblock %}

{% block body %}
    <h1>Les dernières annonces</h1>

    {% if listings is empty %}
        <p>Aucune annonce disponible pour le moment.</p>
    {% else %}
        <div>
            {% for listing in listings %}
                <div>
                    {% if listing.photoPath %}
                        <img src="{{ asset(listing.photoPath) }}" alt="{{ listing.title }}">
                    {% endif %}
                    <h2>{{ listing.title }}</h2>
                    <p>{{ listing.description|slice(0, 150) }}...</p>
                    <p>Catégorie : {{ listing.category.name }}</p>
                    <p>Publié par : {{ listing.author.fullName }}</p>
                    <p>Le : {{ listing.createdAt|date('d/m/Y') }}</p>
                    <a href="#">Voir l'annonce</a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}