{% extends 'base.html.twig' %}

{% block title %}{{ listing.title }}{% endblock %}

{% block body %}

<div class="card" style="max-width: 800px; margin: 40px auto;">

    {% if listing.photoPath %}
        <img src="{{ asset(listing.photoPath) }}" alt="{{ listing.title }}" style="width:100%; border-radius:12px; margin-bottom:20px;">
    {% endif %}

    <h1>{{ listing.title }}</h1>

    <p class="text-muted">
        {{ listing.category.name }} • publié le {{ listing.createdAt|date('d/m/Y') }}
    </p>

    <p style="margin-top:20px;">
        {{ listing.description }}
    </p>

    <div class="mt-20 flex space-between">
        <span class="badge badge-secondary">
            {{ listing.category.name }}
        </span>

        <span class="text-muted">
            par {{ listing.author.fullName }}
        </span>
    </div>

    <div class="mt-20 flex">
        <a href="{{ path('app_listing_index') }}" class="btn btn-secondary">
            Retour
        </a>

        {% if app.user == listing.author or is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_listing_edit', {'id': listing.id}) }}" class="btn btn-primary">
                Modifier
            </a>

            {{ include('listing/_delete_form.html.twig') }}
        {% endif %}
    </div>

</div>

{% endblock %}