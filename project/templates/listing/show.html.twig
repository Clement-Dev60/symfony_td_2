{% extends 'base.html.twig' %}

{% block title %}{{ listing.title }}{% endblock %}

{% block body %}
    <h1>{{ listing.title }}</h1>

    <table>
        <tbody>
            <tr>
                <th>Description</th>
                <td>{{ listing.description }}</td>
            </tr>
            <tr>
                <th>Catégorie</th>
                <td>{{ listing.category.name }}</td>
            </tr>
            <tr>
                <th>Publié par</th>
                <td>{{ listing.author.fullName }}</td>
            </tr>
            <tr>
                <th>Date de publication</th>
                <td>{{ listing.createdAt|date('d/m/Y à H:i') }}</td>
            </tr>
            {% if listing.photoPath %}
            <tr>
                <th>Photo</th>
                <td><img src="{{ asset(listing.photoPath) }}" alt="{{ listing.title }}" style="max-width: 300px"></td>
            </tr>
            {% endif %}
        </tbody>
    </table>

    <a href="{{ path('app_listing_index') }}">Retour à la liste</a>

    {% if app.user == listing.author or is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_listing_edit', {'id': listing.id}) }}">Modifier</a>
        {{ include('listing/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}